本地的文件夹称为工作树，开发工作在工作做中进行，add命令之后文件加入暂存区(Stage或者Index)，暂存区是提交之前的一个临时区域

//配置git的用户名及邮箱地址
git config --global user.name "username"
git config --global user.email "xxxx@qq.com"

//显示配置文件信息
git config --list
//设置界面颜色
git config --global color.ui auto

//从远程仓库克隆到本地
git clone github.com//helloworld.git

//将文件加入本地仓库的暂存区
git add hello.txt
//文件提交到本地仓库
gir commit -m "remark"

//查看提交日志
git log
git log --pretty-short  //简单log信息
git log hello.txt  //只显示该文件的提交日志
git log -p  //查看提交前后文件的区别
git log --graph  //以图表形式查看分支
git reflog  //查看当前仓库的操作日志

//同步到远程仓库
git push

//初始化本地仓库
git init
//查看本地仓库的状态
git status

//提交到本地仓库，将当前暂存区中的文件实际保存到本地仓库的历史记录中
git commit -m 'remark'
git commit -am "remark"   //将add和commit合并完成
git commit --amend [fileName] //重新提交用来替代上一次提交，文件没有修改则用来改写上一次提交的提交信息

//查看暂存区的文件
git ls-files

//查看工作树、暂存区、最新提交之间的差别
git diff   //“+”表示新添加的行，“-”表示删除的行
//查看工作树和最新提交的差别
git diff HEAD

//显示本地分支列表
git branch  //*表示当前所有分支
git branch -a  //查看当前分支的相关信息
git branch -r  //列出所有远程分支
//创建分支
git branch branchName
//切换到指定分支
git check branchName
//创建分支切换到分支
git checkout -b branchName
//切换到上一个分支
git checkout -
//合并分支
git checkout master   //先切换到主分支
git merge --no-ff branchName  //再将分支合并到主分支
//删除分支
git branch -d branchName
//删除远程分支
git push origin --delete branchName

//恢复暂存区的指定文件到工作区
git checkout fileName
//恢复暂存区的所有文件到工作区
git checkout .
//重置暂存区的指定文件，与上一次commit保持一致，但工作区不变
git reset fileName
//重置暂存与工作区，与上一次commit保持一致
git reset --hard

//回溯到历史版本
git reset --hard gdksfjgsdfjlkjdsflk098dfj  //通过时间点哈希值回溯到指定版本

//列出所有tag
git tag
git tag tagName  //新建一个tag
git tag -d tagName  //删除tag
git push origin :refs/tags/tagName  //删除远程tag
git show tagName  //查看tag信息
git push remoteName tagName  //查看tag信息
git push remoteName --tags  //提交所有tag

//合并两次log记录
git rebase -i HEAD~2  //打开两次log记录
在弹出的编辑器中修改第二行的pick为fixup  //将第二次log记录删除合并到第一次log记录

//链接远程仓库
git remote add origin git@github.com:git-book/git-tur.git

//上传到远程仓库的主分支
git push -u origin master  //同时意味着将来pull也是从主分支拿代码
git push -u origin branchName  //从本地仓库的分支上传到远程仓库的分支,远程仓库没有则新建该分支
git push remoteName -d branchName  //删除远程分支

//获取远程仓库的分支
git checkout -b branchName origin/branchName
git push  //从远程仓库分支获取的代码修改后再上传到远程仓库的分支

//从远程仓库的分支更新本地仓库分支
git pull origin branchName

//下载远程仓库的所有变动
git fetch remoteName
//取回远程仓库的变化，并与本地分支合并
git pull remoteName branchName
//上传本地指定分支到远程仓库
git push remoteName branchName
//推送所有分支到远程仓库
git push remoteName --all

//暂存当前文档修改进度
git stash
//取回之前的修改进度
git stash pop

//修改配置文件
git config --local -e


//取消所有文件的跟踪
git rm -r --cached .


