using System;
using System.Threading;
namespace pro
{
	class Class1
	{
		static Thread thread1,thread2;
		static void Main()
		{
			thread1 = new Thread(ThreadProc);
			thread1.Name = "Thread1";
			thread1.Start();

			thread2 = new Thread(ThreadProc);
			thread2.Name="Thread2";
			thread2.Start();
		}

		//整个流程先运行thread1，然后等待thread2运行2秒，之后thread1因为thread2超时继续运行，之后两个线程并发运行，thread2先运行完进入任意键等待，然后thread1运行完进入任意键等待
		static void ThreadProc()
		{
			Console.WriteLine("\nCurrent thread:{0}",Thread.CurrentThread.Name);
			if(Thread.CurrentThread.Name == "Thread1" && thread2.ThreadState != ThreadState.Unstarted)  //thread1需要等待thread2
			{
				if(thread2.Join(2000))   //此处需要等待thread2 2秒，但Sleep需要4秒，所有会运行else显示超时
				{
					Console.WriteLine("Thread2 has termminated.");
				}
				else
				{
					Console.WriteLine("The timeout has elapsed and Thread1 will resume.");
				}
			}
			Thread.Sleep(4000);   //两个线程都需要休眠4秒
			Console.WriteLine("\nCurrent thread:{0}",Thread.CurrentThread.Name);
			Console.WriteLine("Thread1:{0}",thread1.ThreadState);
			Console.WriteLine("Thread2:{0}",thread2.ThreadState);
			Console.ReadKey();  //两个线程各需要按一次任意键才能退出程序
		}
	}
}

/*Thread.Sleep(0)这样调用会导致线程立即放弃当前的时间片，自动将CPU移交给其它线程
Thread.Yield()做同样的事情，但是它只会把执行交给同一处理器上的其它线程
Sleep(0)或Yield有时在高级性能调试的生产代码中很有用。它也是一个很好的诊断工具，有助于发现线程安全问题：
如果在代码中的任何地方插入Threa.Yield()就破坏了程序，那么你的程序几乎肯定有bug

bool blocked=(someThread.ThreadState & ThreadState.WaitSleepJoin)!=0;
判断线程是否被堵塞*/