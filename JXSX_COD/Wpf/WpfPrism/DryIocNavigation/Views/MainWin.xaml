<Window x:Class="DryIocNavigation.ViewModels.MainWin"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:DryIocNavigation.ViewModels"
        xmlns:p="http://prismlibrary.com/"
        mc:Ignorable="d"
        Title="MainWin" Height="450" Width="500">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="80"></RowDefinition>
            <RowDefinition/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition/>
            </Grid.ColumnDefinitions>
            <Button Content="page1" Width="100" Height="50" FontSize="20" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Right" VerticalAlignment="Center" Command="{Binding BtnCommand}" CommandParameter="NpageA"></Button>
            <!--<TextBlock Text="{Binding TestText}" FontSize="50" Grid.Row="0" Grid.Column="0" HorizontalAlignment="Left"></TextBlock>-->
            <Button Content="page2" Width="100" Height="50" FontSize="20" Grid.Row="0" Grid.Column="1" HorizontalAlignment="Left" VerticalAlignment="Center" Command="{Binding BtnCommand}" CommandParameter="NpageB"></Button>
        </Grid>
        <!--<TabControl Grid.Row="1" p:RegionManager.RegionName="pageNavigate"></TabControl>-->
        <ContentControl Grid.Row="1" p:RegionManager.RegionName="pageNavigate"></ContentControl>
        <!--<ItemsControl Grid.Row="1" p:RegionManager.RegionName="pageNavigate"></ItemsControl>-->
    </Grid>
</Window>