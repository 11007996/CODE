<!DOCTYPE html>
<html lang="en">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <meta http-equiv="X-UA-Compatible" content="ie=edge">
    <title>设备数据可视化</title>

    <link rel="stylesheet" href="./Content/index.css">
    <link rel="stylesheet" href="./fonts/icomoon.css">
</head>

<body>
    <div class="header">
        <div class="column"><img class="logo" src="./Images/lux.png" /></div>
        <div class="column "><div class="tilte">协讯设备管理系统</div><div class="subTitle">◇智能看板</div></div>
        <div class="column"><span class="currTime">00-00 00:00:00</span></div>
    </div>
    <div class="viewport">
        <div class="column">
            <div class="overview panel">
                <div id="MachineStateStat" class="inner">
                    <div class="item">
                        <h4>0</h4>
                        <span>
                            <i class="icon-dot" style="color: #006cff"></i>
                            设备总数
                        </span>
                    </div>
                    <div class="item">
                        <h4>0</h4>
                        <span>
                            <i class="icon-dot" style="color: green"></i>
                            正常设备
                        </span>
                    </div>
                    <div class="item">
                        <h4>0</h4>
                        <span>
                            <i class="icon-dot" style="color: gray"></i>
                            闲置设备
                        </span>
                    </div>
                    <div class="item">
                        <h4>0</h4>
                        <span>
                            <i class="icon-dot" style="color: #ed3f35"></i>
                            故障设备
                        </span>
                    </div>
                </div>
            </div>
            <!--设备实时上报-->
            <!-- 设备实时节拍 -->
            <div class="top panel">
                <div class="inner">
                    <div class="province">
                        <h3>设备上报<i class="date">实时 //</i><i class="date">&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp&nbsp</i><i class="date">//产量</i></h3>
                        <div class="data">
                            <ul id="MachineReports" class="sup">
                                @*<li>
                                        <span>A1-01线 HDMI绕线贴束线片模组(1)</span>
                                        <span>2.179 <s class="icon-up"></s></span>
                                    </li>*@
                            </ul>
                            <ul class="sub">
                                <!-- <li><span>数据</span><span> 数据<s class="icon-up"></s></span></li> -->
                            </ul>
                        </div>
                    </div>
                </div>
            </div>
            <!--平均OEE统计-->
            <div class="point panel">
                <div class="inner">
                    <h3>平均OEE统计</h3>
                    <div class="chart">
                        <div class="pie"></div>
                        <div class="data">
                            <div class="item">
                                <h4 id="AvgOEE">0%</h4>
                                <span>
                                    <i class="icon-dot" style="color: #ed3f35"></i>
                                    平均OEE
                                </span>
                            </div>
                            <div class="item">
                                <h4 id="AvgOEECount">0</h4>
                                <span>
                                    <i class="icon-dot" style="color: #eacf19"></i>
                                    统计个数
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
        <div class="column">
            <div class="lineCallStat panel">
                <div class="inner">
                    <!-- 24H故障次数 -->
                    <h3>
                        <span class="icon-cube"></span>
                        24H呼叫次数
                    </h3>
                    <div class="chart ">
                        <div class="bar"></div>
                    </div>
                    <!-- 最新监听状态 -->
                    <div id="MachineCurrState" class="machineState">
                        <div class="data">
                            <h3>
                                <i class="icon-dot" style="color: blue"></i>
                                全部
                            </h3>
                            <h3>0</h3>
                            <h3></h3>
                        </div>
                        <div class="data">
                            <h3>
                                <i class="icon-dot" style="color: green"></i>
                                运行
                            </h3>
                            <h3>0</h3>
                            <h3>0%</h3>
                        </div>
                        <div class="data">
                            <h3>
                                <i class="icon-dot" style="color: red"></i>
                                待机
                            </h3>
                            <h3>0</h3>
                            <h3>0%</h3>
                        </div>
                        <div class="data">
                            <h3>
                                <i class="icon-dot" style="color: yellow"></i>
                                报警
                            </h3>
                            <h3>0</h3>
                            <h3>0%</h3>
                        </div>
                        <div class="data">
                            <h3>
                                <i class="icon-dot" style="color: gray"></i>
                                停机
                            </h3>
                            <h3>0</h3>
                            <h3>0%</h3>
                        </div>
                    </div>

                </div>
            </div>
            <!-- 设备OEE -->
            <div class="machineOEE panel">
                <div class="inner">
                    <h3>设备综合OEE</h3>
                    <div class="chart">
                        <div class="bar"></div>
                    </div>
                </div>
            </div>
        </div>
        <div class="column">
            <!-- 能耗分析 -->
            <div class="order panel">
                <div class="inner">
                    <!-- 筛选 -->
                    <div class="filter">
                        <a href="javascript:;" data-key="day90" class="active">90天</a>
                        <a href="javascript:;" data-key="day30">30天</a>
                        <a href="javascript:;" data-key="day1">24小时</a>
                    </div>
                    <!-- 数据 -->
                    <div class="data">
                        <div class="item">
                            <h4>0</h4>
                            <span>
                                <i class="icon-dot" style="color: #ed3f35;"></i>
                                开机时数(H)
                            </span>
                        </div>
                        <div class="item">
                            <h4>0</h4>
                            <span>
                                <i class="icon-dot" style="color: #eacf19;"></i>
                                能耗(KWH)
                            </span>
                        </div>
                    </div>
                </div>
            </div>
            <!-- 呼叫记录 -->
            <div class="sales panel">
                <div class="inner">
                    <div class="caption">
                        <h3>呼叫记录</h3>
                        <a href="javascript:;" data-type="month">月</a>
                        <a href="javascript:;" data-type="week">周</a>
                    </div>
                    <div class="chart">
                        <div class="line"></div>
                    </div>
                </div>
            </div>

            <div class="wrap">
                <!-- 设备 分布 -->
                <div id="MachineDistribute" class="channel panel">
                    <div class="inner">
                        <h3>设备分布</h3>
                        <div class="data">
                            <div class="item">
                                <h4>0 <small>%</small></h4>
                                <span>
                                    A区
                                </span>
                            </div>
                            <div class="item">
                                <h4>0 <small>%</small></h4>
                                <span>
                                    B区
                                </span>
                            </div>
                        </div>
                        <div class="data">
                            <div class="item">
                                <h4>0 <small>%</small></h4>
                                <span>
                                    C区
                                </span>
                            </div>
                            <div class="item">
                                <h4>0 <small>%</small></h4>
                                <span>
                                    D区
                                </span>
                            </div>
                        </div>
                    </div>
                </div>
                <div class="quarter panel">
                    <div class="inner">
                        <h3>上周同比增长</h3>
                        <div class="chart">
                            <div class="box">
                                <div class="gauge"></div>
                                <div class="label" id="preWeekRate">0<small> %</small></div>
                            </div>
                            <div class="data">
                                <div class="item">
                                    <h4 id="currWeekCount">0</h4>
                                    <span>
                                        <i class="icon-dot" style="color: #6acca3"></i>
                                        本周故障
                                    </span>
                                </div>
                                <div class="item">
                                    <h4 id="preMonthRate">0<small> %</small></h4>
                                    <span>
                                        <i class="icon-dot" style="color: #ed3f35"></i>
                                        上月同比
                                    </span>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
            <!--监控-->
            <div class="monitor panel">
                <div class="inner">
                    <div class="tabs">
                        <h3>异常设备监控</h3>
                    </div>
                    <div class="content" style="display: block;">
                        <div class="head">
                            <span class="col">故障时间</span>
                            <span class="col">设备地址</span>
                            <span class="col">异常代码</span>
                        </div>
                        <div class="marquee-view">
                            <div id="MachineWarnReports" class="marquee">
                                @*<div class="row">
                                           <span class="col">20180701</span>
                                           <span class="col">HDMI旋转焊锡模组</span>
                                           <span class="col">1000001</span>
                                           <span class="icon-dot"></span>
                                    </div>*@
                            </div>
                        </div>
                    </div>
                </div>
            </div>

        </div>
    </div>
    <script src="./Scripts/jquery.min.js"></script>
    <script src="./Scripts/echarts.min.js"></script>
    <script src="./Scripts/china.js"></script>
    <script src="./Scripts/DateFrm.js"></script>
    <script src="./Scripts/index.js"></script>

</body>



</html>