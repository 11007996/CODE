<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:controls="using:LuxVideoDet.Desktop.Views.Controls"
        xmlns:vm="using:LuxVideoDet.Desktop.ViewModels"
        x:Class="LuxVideoDet.Desktop.Views.FullscreenPreviewWindow"
        x:DataType="vm:MainWindowViewModel"
        Title="{Binding FullscreenViewTitle}"
        WindowState="FullScreen"
        Background="Black">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="85*"/>
            <ColumnDefinition Width="15*"/>
        </Grid.ColumnDefinitions>
        <Grid.RowDefinitions>
            <RowDefinition Height="85*"/>
            <RowDefinition Height="15*"/>
        </Grid.RowDefinitions>

        <Viewbox Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                 Stretch="Uniform">
            <Image x:Name="PreviewImage" Stretch="Uniform"/>
        </Viewbox>

        <Border ZIndex="1" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                VerticalAlignment="Top" HorizontalAlignment="Right"
                Margin="20" Padding="12,8" CornerRadius="8"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Opacity="0.92">
            <TextBlock Text="{Binding FullscreenEscHintText}"
                       Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                       FontSize="12" Opacity="0.9"/>
        </Border>

        <Border ZIndex="1" Grid.Row="0" Grid.Column="0" Grid.RowSpan="2" Grid.ColumnSpan="2"
                VerticalAlignment="Bottom" HorizontalAlignment="Left"
                Margin="20" Padding="16,12" CornerRadius="8"
                Background="{DynamicResource SystemControlBackgroundChromeMediumBrush}"
                BorderBrush="{DynamicResource SystemControlForegroundBaseLowBrush}"
                BorderThickness="1"
                Opacity="0.92">
            <StackPanel Spacing="8">
                <TextBlock Text="{Binding FullscreenOverlayConfigName}"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           FontSize="16" FontWeight="SemiBold"/>
                <TextBlock Text="{Binding FullscreenOverlayPipelineText}"
                           Foreground="{DynamicResource SystemControlForegroundBaseHighBrush}"
                           FontSize="14" Opacity="0.9"/>
            </StackPanel>
        </Border>

        <controls:AlgorithmUiActionsOverlay Grid.Row="0" Grid.Column="0" ZIndex="2"/>
    </Grid>
</Window>
