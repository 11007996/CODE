@page
@{
    Layout = ""; //禁用默认布局
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>上线通知单</title>
    @await Html.PartialAsync("_DashboardScriptsPartial")
    <link rel="stylesheet" href="~/dashboard/02C1/onlineNotice/css/index.css">
    <script>

        //窗体缩放调整html字体大小
        $(document).ready(function () {
            var whei = $(window).width()
            $("html").css({ fontSize: whei / 22 });
            $(window).resize(function () {
                var whei = $(window).width();
                $("html").css({ fontSize: whei / 22 })
            });
        });

    </script>
</head>
<body eam-hasPermi="dashboard:02C1:onlineNotice" eam-loginFactory="02C1">

    <div class="main">
        <!--头部标题-->
        <div class="header">
            <div class="header-left fl" id="time"></div>
            <div class="header-center fl">
                <div class="header-title">
                    协讯二期智能上线管理看板
                </div>
                <div class="header-img"></div>
            </div>
            <div class="header-right fl">
            </div>
        </div>

        <div class="center">

            <div class="center-left fl">
                <div class="title">上线通知单【待处理】</div>
                <div class="list-container">
                    <ul id="ticketList" class="list-group list-group-flush">
                       @*  <li id="ticket-item" class="list-group-item list-group-item-action active" data-ticket-no="">
                            <label class="">编号:NB12345648789</label>
                            <label class="">申请:刘文波</label>
                        </li> *@
                    </ul>
                </div>
            </div>

            <div class="center-cen">
                <!--基本信息-->
                <div class="info">
                    <div class="row g-0">
                        <label class="col-2 info-title">业务单号</label>
                        <label class="col-2 info-value" id="ticketNo"></label>
                        <label class="col-2 info-title">申请人</label>
                        <label class="col-3 info-value" id="initiatorName"></label>
                        <label class="col-2 info-title">需求时间</label>
                        <label class="col-1 info-value" id="needTime"></label>
                    </div>
                    <div class="row g-0">
                        <label class="info-title">上线料号</label>
                        <label class="info-value" id="newPartName"></label>
                        <label class="info-title">在制料号</label>
                        <label class="info-value" id="oldPartName"></label>
                        <label class="info-title">批量</label>
                        <label class="info-value" id="productQty"></label>
                        <label class="info-title">线别</label>
                        <label class="info-value" id="lineName"></label>
                    </div>
                </div>
                <!--设备*治具信息-->

                <div class="item-container">
                    <div class="row g-0">
                        <label class="col-5 item-title">设备*治具</label>
                        <label class="col-1 item-title">数量</label>
                        <label class="col-5 item-title">设备*治具</label>
                        <label class="col-1 item-title">数量</label>
                    </div>
                    <div id="itemNavList" class="itemList">
                     @*    <div class="row g-0">
                            <label class="col-5 item-name">测试治具1</label>
                            <label class="col-1 item-qty">99</label>
                            <label class="col-5 item-name">测试治具2</label>
                            <label class="col-1 item-qty">10</label>
                        </div> *@
                    </div>
                </div>
            </div>
        </div>

    </div>
    @await Html.PartialAsync("_Copyright")
    <script src="~/api/business.js"></script>
    <script src="~/dashboard/02C1/onlineNotice/js/fontscroll.js"></script>
    <script src="~/dashboard/02C1/onlineNotice/js/index.js"></script>
    <script>
        setInterval(function () {
            var nowTime = getTime();
            $('#time').html(nowTime);
        }, 1000);


        let html = document.documentElement;// 获取html
        let rowh = parseInt(1.25 * parseInt(html.style.fontSize)) + 2
        $(function () {
            $('.myscroll').myScroll({
                speed: 80, //数值越大，速度越慢
                rowHeight: rowh //li的高度
            });
        });
    </script>

</body>
</html>