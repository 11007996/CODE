<mapper namespace="com.ruoyi.dpms.mapper.MesKpiDetailMapper">
    <resultMap type="com.ruoyi.dpms.domain.MesKpiDetail" id="MesKpiDetailResult">
        <result property="id"    column="id"    />
        <result property="assignId"    column="assign_id"    />
        <result property="targetParam"    column="target_param"    />
        <result property="targetValue"    column="target_value"    />
        <result property="targetStandard"    column="target_standard"    />
        <result property="actualValue"    column="actual_value"    />
