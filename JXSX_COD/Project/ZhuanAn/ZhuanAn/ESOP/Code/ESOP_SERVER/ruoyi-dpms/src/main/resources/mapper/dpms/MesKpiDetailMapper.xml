            <if test="filledPerson != null">filled_person,</if>
            <if test="personLiable != null">person_liable,</if>
            <if test="notifyPerson != null">notify_person,</if>
            <if test="filledDate != null">filled_date,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="assignId != null">#{assignId},</if>
            <if test="targetParam != null">#{targetParam},</if>
            <if test="targetValue != null">#{targetValue},</if>
            <if test="targetStandard != null">#{targetStandard},</if>
            <if test="actualValue != null">#{actualValue},</if>
            <if test="status != null">#{status},</if>
            <if test="filledPerson != null">#{filledPerson},</if>
