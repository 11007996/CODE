            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <delete id="deleteMesKpiDetailByAssignId" parameterType="Long">
        delete from mes_kpi_dept_detail where assign_id = #{mkdAssignId}
    </delete>


    <delete id="deleteMesKpiDetailById" parameterType="Long">
        delete from mes_kpi_dept_detail where id = #{id}
    </delete>

