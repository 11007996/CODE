    <select id="selectMesKpiFillList" parameterType="com.ruoyi.dpms.domain.MesKpiFill" resultMap="MesKpiFillResult">
        SELECT DISTINCT a.id,
        a.kpi_id,
        a.weight_coefficient,
        a.statistical_cycle,
        a.kpi_year,
        b.kpi_index,
        b.units,
        b.calculation_formula ,
        c.target_standard,
        f.user_name,
        h.dept_id
        FROM
        mes_kpi_assign A,
        mes_kpi_index B,
        mes_kpi_dept_detail C,
        mes_kpi_dept_group D,
        sys_user F,
        sys_dept H
        WHERE
        a.kpi_id = b.id
        AND a.id = c.assign_id
        AND f.user_name = #{userAccount}
        AND h.dept_id = #{deptId}
        AND d.user_account = #{userAccount}

    </select>


