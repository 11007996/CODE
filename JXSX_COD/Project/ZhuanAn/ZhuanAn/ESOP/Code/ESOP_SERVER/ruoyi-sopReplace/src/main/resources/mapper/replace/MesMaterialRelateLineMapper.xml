<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.replace.mapper.MesMaterialRelateLineMapper">

    <resultMap type="com.ruoyi.replace.domain.MesMaterialRelateLine" id="MesMaterialRelateLineResult">
        <result property="id"    column="id"    />
        <result property="materialId"    column="material_id"    />
        <result property="lineId"    column="line_id"    />
        <result property="lineName"    column="line_name"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectMesMaterialRelateLineVo">
        select material_id, line_id, create_by, create_time, update_by, update_time from mes_material_relate_line
    </sql>

    <select id="selectMesMaterialRelateLineList" parameterType="com.ruoyi.replace.domain.MesMaterialRelateLine" resultMap="MesMaterialRelateLineResult">
        <include refid="selectMesMaterialRelateLineVo"/>
        <where>
            <if test="materialId != null "> and material_id = #{materialId}</if>
            <if test="lineId != null "> and line_id = #{lineId}</if>
            <if test="lineName != null "> and line_name = #{lineName}</if>
        </where>
    </select>

    <select id="selectMesMaterialRelateLineById" parameterType="Long" resultMap="MesMaterialRelateLineResult">
        <include refid="selectMesMaterialRelateLineVo"/>
        where id = #{id}
    </select>

    <insert id="insertMesMaterialRelateLine" parameterType="com.ruoyi.replace.domain.MesMaterialRelateLine" useGeneratedKeys="true" keyProperty="id">
        insert into mes_material_relate_line
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="materialId != null">material_id,</if>
            <if test="lineId != null">line_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="materialId != null">#{materialId},</if>
            <if test="lineId != null">#{lineId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
        </trim>
    </insert>

    <update id="updateMesMaterialRelateLine" parameterType="com.ruoyi.replace.domain.MesMaterialRelateLine">
        update mes_material_relate_line
        <trim prefix="SET" suffixOverrides=",">
            <if test="lineId != null">material_id = #{materialId},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where line_id = #{lineId}
    </update>

    <delete id="deleteMesMaterialRelateLineById" parameterType="Long">
        delete from mes_material_relate_line where line_id = #{lineId}
    </delete>
    <delete id="deleteMesMaterialRelateLineByMId" parameterType="Long">
        delete from mes_material_relate_line where material_id = #{materialId}
    </delete>

    <delete id="deleteMesMaterialRelateLineByIds" parameterType="String">
        delete from mes_material_relate_line where id in
        <foreach item="id" collection="array" open="(" separator="," close=")">
            #{id}
        </foreach>
    </delete>

    <select id="selectLineByMaterial" parameterType="Long" resultMap="MesMaterialRelateLineResult">
        SELECT A.line_id,A.material_id,A.update_by,A.update_time,B.line_name
        FROM mes_material_relate_line A,
        mes_line B
        WHERE A.material_id = #{materialId}
        AND A.line_id = B.line_id
    </select>
</mapper>