<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.product.mapper.MesSealMapper">

    <resultMap type="MesSeal" id="MesSealResult">
        <result property="sealId"    column="seal_id"    />
        <result property="sealName"    column="seal_name"    />
        <result property="filePath"    column="file_path"    />
        <result property="type"    column="type"    />
        <result property="status"    column="status"    />
        <result property="custodianNo"    column="custodian_no"    />
        <result property="deptId"    column="dept_id"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
        <result property="delFlag"    column="del_flag"    />
    </resultMap>

    <sql id="selectMesSealVo">
        select seal_id, file_path, type, status, custodian_no, dept_id, create_by, create_time, update_by, update_time, del_flag from mes_seal
    </sql>

    <select id="selectMesSealList" parameterType="MesSeal" resultMap="MesSealResult">
        <include refid="selectMesSealVo"/>
        <where>
            <if test="type != null  and type != ''"> and type = #{type}</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
            <if test="custodianNo != null  and custodianNo != ''"> and custodian_no = #{custodianNo}</if>
            <if test="deptId != null "> and dept_id = #{deptId}</if>
        </where>
    </select>

    <select id="selectMesSealBySealId" parameterType="Long" resultMap="MesSealResult">
        <include refid="selectMesSealVo"/>
        where seal_id = #{sealId}
    </select>

    <insert id="insertMesSeal" parameterType="MesSeal" useGeneratedKeys="true" keyProperty="sealId">
        insert into mes_seal
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="sealName != null and sealName != ''">seal_name,</if>
            <if test="filePath != null">file_path,</if>
            <if test="type != null">type,</if>
            <if test="status != null">status,</if>
            <if test="custodianNo != null and custodianNo != ''">custodian_no,</if>
            <if test="deptId != null">dept_id,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
            <if test="delFlag != null">del_flag,</if>
        </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="sealName != null and sealName != ''">#{sealName},</if>
            <if test="filePath != null">#{filePath},</if>
            <if test="type != null">#{type},</if>
            <if test="status != null">#{status},</if>
            <if test="custodianNo != null and custodianNo != ''">#{custodianNo},</if>
            <if test="deptId != null">#{deptId},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
            <if test="delFlag != null">#{delFlag},</if>
        </trim>
    </insert>

    <update id="updateMesSeal" parameterType="MesSeal">
        update mes_seal
        <trim prefix="SET" suffixOverrides=",">
            <if test="sealName != null and sealName != ''">seal_name = #{sealName},</if>
            <if test="filePath != null">file_path = #{filePath},</if>
            <if test="type != null">type = #{type},</if>
            <if test="status != null">status = #{status},</if>
            <if test="custodianNo != null and custodianNo != ''">custodian_no = #{custodianNo},</if>
            <if test="deptId != null">dept_id = #{deptId},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
        </trim>
        where seal_id = #{sealId}
    </update>

    <delete id="deleteMesSealBySealId" parameterType="Long">
        delete from mes_seal where seal_id = #{sealId}
    </delete>

    <delete id="deleteMesSealBySealIds" parameterType="String">
        delete from mes_seal where seal_id in
        <foreach item="sealId" collection="array" open="(" separator="," close=")">
            #{sealId}
        </foreach>
    </delete>
</mapper>