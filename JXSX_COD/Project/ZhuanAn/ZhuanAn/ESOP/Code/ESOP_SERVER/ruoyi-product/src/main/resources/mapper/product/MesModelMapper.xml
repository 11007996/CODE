<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
"http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="com.ruoyi.product.mapper.MesModelMapper">

    <resultMap type="MesModel" id="MesModelResult">
        <result property="modelId"    column="model_id"    />
        <result property="modelName"    column="model_name"    />
        <result property="status"    column="status"    />
        <result property="remark"    column="remark"    />
        <result property="createBy"    column="create_by"    />
        <result property="createTime"    column="create_time"    />
        <result property="updateBy"    column="update_by"    />
        <result property="updateTime"    column="update_time"    />
    </resultMap>

    <sql id="selectMesModelVo">
        select model_id, model_name, status, remark, create_by, create_time, update_by, update_time from mes_model
    </sql>

    <select id="selectMesModelList" parameterType="MesModel" resultMap="MesModelResult">
        <include refid="selectMesModelVo"/>
        <where>
            <if test="modelName != null  and modelName != ''"> and model_name like concat('%', #{modelName}, '%')</if>
            <if test="status != null  and status != ''"> and status = #{status}</if>
        </where>
    </select>

    <select id="selectMesModelByModelId" parameterType="Long" resultMap="MesModelResult">
        <include refid="selectMesModelVo"/>
        where model_id = #{modelId}
    </select>

    <select id="checkModelNameUnique" parameterType="String" resultMap="MesModelResult">
        <include refid="selectMesModelVo"/>
        where model_name=#{modelName} limit 1
    </select>

    <insert id="insertMesModel" parameterType="MesModel" useGeneratedKeys="true" keyProperty="modelId">
        insert into mes_model
        <trim prefix="(" suffix=")" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">model_name,</if>
            <if test="status != null">status,</if>
            <if test="remark != null">remark,</if>
            <if test="createBy != null">create_by,</if>
            <if test="createTime != null">create_time,</if>
            <if test="updateBy != null">update_by,</if>
            <if test="updateTime != null">update_time,</if>
         </trim>
        <trim prefix="values (" suffix=")" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">#{modelName},</if>
            <if test="status != null">#{status},</if>
            <if test="remark != null">#{remark},</if>
            <if test="createBy != null">#{createBy},</if>
            <if test="createTime != null">#{createTime},</if>
            <if test="updateBy != null">#{updateBy},</if>
            <if test="updateTime != null">#{updateTime},</if>
         </trim>
    </insert>

    <update id="updateMesModel" parameterType="MesModel">
        update mes_model
        <trim prefix="SET" suffixOverrides=",">
            <if test="modelName != null and modelName != ''">model_name = #{modelName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="remark != null">remark = #{remark},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
        </trim>
        where model_id = #{modelId}
    </update>

    <delete id="deleteMesModelByModelId" parameterType="Long">
        delete from mes_model where model_id = #{modelId}
    </delete>

    <delete id="deleteMesModelByModelIds" parameterType="String">
        delete from mes_model where model_id in
        <foreach item="modelId" collection="array" open="(" separator="," close=")">
            #{modelId}
        </foreach>
    </delete>
    <select id="modelInfoByName" parameterType="String" resultMap="MesModelResult">
        select * from mes_model
        where model_name = #{modelName}
    </select>
</mapper>
