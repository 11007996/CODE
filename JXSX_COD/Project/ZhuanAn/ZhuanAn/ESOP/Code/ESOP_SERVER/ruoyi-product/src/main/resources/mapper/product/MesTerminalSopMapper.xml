        <select id="selectMesTerminalSopListPushed" parameterType="com.ruoyi.product.domain.MesTerminalSop" resultMap="MesTerminalSopResult">
            SELECT DISTINCT
            T.*
            FROM
            (
            SELECT
            a.id,
            a.model_id,
            n.model_name,
            a.material_id,
            m.material_name,
            a.line_id,
            c.line_name,
            a.stage_id,
            d.stage_name,
            a.process_id,
            e.process_name,
            f.mac_id,
            f.mac_name,
            h.sop_id,
            g.sop_name,
            h.sop_page,
            g.version,
            g.status,
            a.remark,
            h.push_status,
            g.pass_word
            FROM
            mes_terminal_sop a
            LEFT JOIN mes_line c ON a.line_id = c.line_id
            LEFT JOIN mes_stage d ON a.stage_id = d.stage_id
            LEFT JOIN mes_process e ON a.process_id = e.process_id
            LEFT JOIN mes_mac f ON a.terminal_id = f.mac_id
            LEFT JOIN mes_sop_group h ON a.id = h.sop_group_id
            LEFT JOIN mes_sop g ON h.sop_id = g.sop_id
            LEFT JOIN mes_model n ON a.model_id = n.model_id
            LEFT JOIN mes_material_info m ON a.material_id = m.id
            <where>
                <if test="lineId != null "> and a.line_id = #{lineId}</if>
                <if test="stageId != null "> and a.stage_id = #{stageId}</if>
                <if test="processId != null "> and a.process_id = #{processId}</if>
                <if test="terminalId != null "> and a.terminal_id = #{terminalId}</if>
                <if test="version != null "> and a.version = #{terminalId}</if>
                <if test="status != null  and status != ''"> and a.status = #{status}</if>
                <if test="lineName != null "> and c.line_name like concat('%', #{lineName}, '%')</if>
                <if test="sopName != null "> and g.sop_name like concat('%', #{sopName}, '%')</if>
                AND g.status = 0
                AND h.push_status = 1
            </where>
            ORDER BY a.create_time DESC
            )T
        </select>
