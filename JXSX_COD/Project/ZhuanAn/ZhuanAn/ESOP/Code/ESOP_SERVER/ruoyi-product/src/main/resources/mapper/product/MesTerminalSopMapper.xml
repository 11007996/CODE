    <sql id="selectMesTerminalSopVo">
        select a.id, a.model_id, b.model_name, a.line_id, c.line_name, a.stage_id,d.stage_name, a.process_id, e.process_name,
               a.terminal_id, f.terminal_name, a.sop_id,a.material_id,  a.status, a.remark
        from mes_terminal_sop a
        left join mes_model b on a.model_id = b.model_id
        left join mes_line c on a.line_id = c.line_id
        left join mes_stage d on a.stage_id = d.stage_id
        left join mes_process e on a.process_id = e.process_id
        left join mes_terminal f on a.terminal_id = f.terminal_id
    </sql>

