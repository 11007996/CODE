    <sql id="selectMesTerminalSopHtVo">
        SELECT
        a.id,
        a.model_id,
        a.line_id,
        a.stage_id,
        a.process_id,
        a.terminal_id,
        a.sop_id,
        g.version,
        a.STATUS,
        a.remark
        FROM
        mes_terminal_sop a
        LEFT JOIN mes_sop g ON a.sop_id = g.sop_id
    </sql>

    <select id="selectMesTerminalSopHtList" parameterType="com.ruoyi.product.domain.MesTerminalSopHt" resultMap="MesTerminalSopHtResult">
        <include refid="selectMesTerminalSopHtVo"/>
        <where>
            <if test="modelId != null "> and a.model_id = #{modelId}</if>
            <if test="lineId != null "> and a.line_id = #{lineId}</if>
            <if test="stageId != null "> and a.stage_id = #{stageId}</if>
            <if test="processId != null "> and a.process_id = #{processId}</if>
            <if test="terminalId != null "> and a.terminal_id = #{terminalId}</if>
        </where>
    </select>

</mapper>
