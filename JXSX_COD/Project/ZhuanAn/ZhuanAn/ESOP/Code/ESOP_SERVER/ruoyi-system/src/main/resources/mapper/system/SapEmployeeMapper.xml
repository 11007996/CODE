            <if test="property05 != null">#{property05},</if>
        </trim>
    </insert>

    <update id="updateSapEmployee" parameterType="SapEmployee">
        update sap_employee
        <trim prefix="SET" suffixOverrides=",">
            <if test="employeeNo != null">employee_no = #{employeeNo},</if>
            <if test="employeeName != null">employee_name = #{employeeName},</if>
            <if test="orgCode != null">org_code = #{orgCode},</if>
            <if test="orgName != null">org_name = #{orgName},</if>
            <if test="status != null">status = #{status},</if>
            <if test="mail != null">mail = #{mail},</if>
            <if test="directManager != null">direct_manager = #{directManager},</if>
            <if test="employeeSide != null">employee_side = #{employeeSide},</if>
            <if test="delFlag != null">del_flag = #{delFlag},</if>
            <if test="createBy != null">create_by = #{createBy},</if>
            <if test="createTime != null">create_time = #{createTime},</if>
            <if test="updateBy != null">update_by = #{updateBy},</if>
            <if test="updateTime != null">update_time = #{updateTime},</if>
            <if test="property01 != null">property_01 = #{property01},</if>
            <if test="property02 != null">property_02 = #{property02},</if>
            <if test="property03 != null">property_03 = #{property03},</if>
            <if test="property04 != null">property_04 = #{property04},</if>
            <if test="property05 != null">property_05 = #{property05},</if>
        </trim>
        where employee_id = #{employeeId}
    </update>

    <delete id="deleteSapEmployeeById" parameterType="Long">
        delete from sap_employee where employee_id = #{employeeId}
    </delete>

    <delete id="deleteSapEmployeeByIds" parameterType="String">
        delete from sap_employee where employee_id in
        <foreach item="employeeId" collection="array" open="(" separator="," close=")">
            #{employeeId}
        </foreach>
    </delete>

    <delete id="deleteSapEmployeeTempByIds">
        delete from sap_employee_temp
    </delete>

    <select id="selectOrgCode" parameterType="String" resultMap="SapEmployeeResult">
        select distinct objid AS ORG_CODE,STEXT AS ORG_NAME from hr_department t
        where t.objid = #{orgCode} and mandt=#{client}
    </select>

</mapper>