@model MVC260625.Models.fileTextModels
@{
    Layout = null;
    
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>viewData</title>
    <link href="~/Content/viewStyle.css" rel="stylesheet" />
</head>
<body>
    <div> 
        <p>名字：@Model.name</p>
        <p>年龄：@Model.age</p>

    </div>



